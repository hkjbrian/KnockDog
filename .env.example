# 로컬 개발용 환경변수 템플릿.
# 사용법: cp .env.example .env  → 값 채우기.  (.env 는 커밋 금지)
# - docker compose 는 같은 폴더의 .env 를 자동으로 읽는다.
# - IntelliJ 앱 실행은 EnvFile 플러그인으로 .env 를 로드한다 (README 참고).

# --- DB (docker-compose + 앱 공용) ---
DB_NAME=knockdog
DB_USERNAME=knockdog
DB_PASSWORD=knockdog
DB_ROOT_PASSWORD=root
DB_URL=jdbc:mysql://localhost:3306/knockdog

# --- 카카오 OAuth (인증 기능 구현 시 채움) ---
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=http://localhost:8080/login/oauth2/code/kakao

# --- JWT ---
JWT_SECRET=
